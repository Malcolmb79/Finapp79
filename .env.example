# GoCardless Bank Account Data API credentials.
# Create a free account at https://bankaccountdata.gocardless.com/ to get these.
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Where the bank-link OAuth flow should redirect back to after the user
# authorizes access at their bank.
GOCARDLESS_REDIRECT_URL=http://localhost:5173/bank-link/callback

# SQLite database file location (relative to server/).
DATABASE_PATH=./data/finance.sqlite

PORT=3001
