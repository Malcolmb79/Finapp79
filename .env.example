# Enable Banking API credentials (pan-EU/UK open banking).
#
# 1. Sign up at https://enablebanking.com/sign-in/ and open the Control Panel.
# 2. Generate a private key + self-signed certificate:
#      openssl genrsa -out server/enable_banking_private_key.pem 2048
#      openssl req -new -x509 -key server/enable_banking_private_key.pem \
#        -out enable_banking_cert.pem -days 3650 -subj "/CN=personal-finance-app"
#    (server/enable_banking_private_key.pem is gitignored — never commit it.)
# 3. Upload enable_banking_cert.pem in the Control Panel to register an
#    application, with the environment set to Sandbox (not Production —
#    Production requires HTTPS redirect URLs). IMPORTANT: the Control Panel's
#    redirect URL field rejects "localhost" as a hostname with a bare
#    "invalid URL" error; use 127.0.0.1 instead, as below.
#    Registering gives you back an app_id — that's ENABLE_BANKING_APP_ID.
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_PRIVATE_KEY_PATH=./enable_banking_private_key.pem

# Where the bank-link flow should redirect back to after the user
# authorizes access at their bank. Must exactly match what's registered in
# the Control Panel as an allowed redirect URL (Sandbox environment).
ENABLE_BANKING_REDIRECT_URL=http://127.0.0.1:5173/bank-link/callback

# SQLite database file location (relative to server/).
DATABASE_PATH=./data/finance.sqlite

PORT=3001
CLIENT_URL=http://localhost:5173

# Random long string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this invalidates all existing sessions (everyone gets logged out).
SESSION_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# 1. Create a project (or use an existing one), then "Create Credentials" ->
#    "OAuth client ID" -> Application type "Web application".
# 2. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback
# 3. Copy the Client ID and Client Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Login — https://developers.facebook.com/apps
# 1. Create an app -> add the "Facebook Login" product.
# 2. In Facebook Login > Settings, add valid OAuth redirect URI:
#    http://localhost:3001/api/auth/facebook/callback
# 3. Copy the App ID and App Secret (Settings > Basic) below.
# Note: while the app is in "Development" mode, only you and accounts you add
# as testers (App Roles > Test Users/Roles) can log in with it — that's fine
# for personal use, but Meta requires app review before it works for anyone else.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
