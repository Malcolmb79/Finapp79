# Postgres connection string. Leave unset for local dev — server/src/db/client.ts
# then falls back to @electric-sql/pglite, a WASM Postgres that runs in-process
# with zero external service (data persisted to server/data/pgdata/, gitignored).
#
# For a Vercel deployment: add the Postgres integration (Storage tab ->
# Create Database, Neon-backed) and link it to this project — Vercel injects
# POSTGRES_URL automatically, you don't set it by hand there. To run against
# that same database locally instead of pglite, pull it with
# `vercel env pull .env` (requires the Vercel CLI + `vercel link` first).
POSTGRES_URL=

# Plaid API credentials (open banking — UK/EU/US coverage).
#
# 1. Sign up at https://dashboard.plaid.com/signup — free Sandbox
#    environment with test institutions, no real bank account or billing
#    needed to get started.
# 2. Dashboard -> Team Settings -> Keys gives you a client_id and a
#    per-environment secret (Sandbox vs Production have separate secrets;
#    use the Sandbox one for local dev).
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | production. Real bank data (Production) requires a separate
# Plaid application review after you've verified the integration works
# against Sandbox — see https://dashboard.plaid.com/overview/production.
PLAID_ENV=sandbox

# Where Plaid Link should redirect back to for OAuth institutions (UK/EU
# banks use OAuth almost universally) — must exactly match a redirect URI
# registered in the Plaid dashboard (Team Settings -> API -> Allowed
# redirect URIs). Unlike Enable Banking, plain "localhost" is fine here.
PLAID_REDIRECT_URI=http://localhost:5173/bank-link/callback

PORT=3001
CLIENT_URL=http://localhost:5173

# Resend (https://resend.com) — sends password reset and email verification
# messages. Sign up, verify a sending domain (or use their onboarding@resend.dev
# test address, which only delivers to the account's own email), and create an
# API key under API Keys. Leave unset for local dev: emails are logged to the
# server console instead of actually sent, so you can grab the link from there.
RESEND_API_KEY=
# Must be a verified sender on your Resend account/domain. Defaults to
# Resend's shared test address if unset (fine for local dev, not production).
EMAIL_FROM=

# Random long string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this invalidates all existing sessions (everyone gets logged out).
SESSION_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# 1. Create a project (or use an existing one), then "Create Credentials" ->
#    "OAuth client ID" -> Application type "Web application".
# 2. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback
#    (add your production URL's /api/auth/google/callback too once deployed)
# 3. Copy the Client ID and Client Secret below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Login — https://developers.facebook.com/apps
# 1. Create an app -> add the "Facebook Login" product.
# 2. In Facebook Login > Settings, add valid OAuth redirect URI:
#    http://localhost:3001/api/auth/facebook/callback
# 3. Copy the App ID and App Secret (Settings > Basic) below.
# Note: while the app is in "Development" mode, only you and accounts you add
# as testers (App Roles > Test Users/Roles) can log in with it — that's fine
# for personal use, but Meta requires app review before it works for anyone else.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
